# =============================================================================
# termag backend configuration
# =============================================================================
# Copy this file to .env and fill in real values. Variables without a default
# are required.

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/termag"

# Public-facing URL where the frontend is served. Must match what your reverse
# proxy exposes (Slack OAuth callbacks and CORS depend on this).
FRONTEND_URL="https://example.com"

# Subpath the app is mounted at behind the reverse proxy. Use "" if mounted at
# the domain root, or e.g. "/termag" if proxied at https://example.com/termag.
BASE_PATH="/termag"

# Port the Express server listens on (your reverse proxy forwards to this).
PORT=3040

# Express session secret. Generate with: openssl rand -hex 32
SESSION_SECRET="replace-with-random-secret"

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Google OAuth — create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# Comma-separated list of allowed Google sign-ins. Each entry is one of:
#   email:unixuser        exact mapping (highest priority)
#   @domain.com           anyone in the domain; unix username = email local part
#   @domain.com:unixuser  anyone in the domain mapped to a fixed unix username
# Example: ALLOWED_USERS="admin@example.com:root,@launchdarkly.com"
ALLOWED_USERS="you@example.com:youruser"

# -----------------------------------------------------------------------------
# Slack integration (optional — leave unset to disable)
# -----------------------------------------------------------------------------

# Slack app credentials. Create the app at https://api.slack.com/apps
# Required scopes are documented in deploy/setup.md.
SLACK_BOT_TOKEN="xoxb-..."
SLACK_APP_TOKEN="xapp-..."          # Socket Mode app-level token
SLACK_SIGNING_SECRET="..."

# Comma-separated list mapping allowed Slack user IDs → unix usernames.
# Format: U01ABCDEF:youruser,U02GHIJKL:otheruser
ALLOWED_SLACK_USERS="U01ABCDEF:youruser"

# -----------------------------------------------------------------------------
# Discord integration (optional — leave unset to disable)
# -----------------------------------------------------------------------------

DISCORD_TOKEN=""
DISCORD_APP_ID=""

# Comma-separated list mapping Discord user IDs → unix usernames.
# Format: 123456789012345678:youruser
DISCORD_USER_MAP=""

# -----------------------------------------------------------------------------
# Local relay (Chrome tab capture)
# -----------------------------------------------------------------------------

# Token the local Chrome relay uses to authenticate to the backend.
# Generate with: openssl rand -hex 32
RELAY_TOKEN="replace-with-random-relay-token"

# -----------------------------------------------------------------------------
# Pane capture API (used by Claude Code Stop hook → backend)
# -----------------------------------------------------------------------------

# Shared secret hooks use to POST captured panes to the backend.
# Generate with: openssl rand -hex 32
CAPTURE_API_SECRET="replace-with-random-capture-secret"

# -----------------------------------------------------------------------------
# Tunables (all have defaults — override only if needed)
# -----------------------------------------------------------------------------

# Max seconds to wait for a `claude` CLI invocation before killing it.
CLAUDE_TIMEOUT_SECONDS=120

# Max characters of agent output sent back in a Slack/Discord response.
MAX_RESPONSE_LENGTH=3500

# Min seconds between successive DM commands from the same user.
RATE_LIMIT_SECONDS=2

# How often (ms) to flush partial streaming updates to Slack/Discord.
STREAMING_UPDATE_INTERVAL_MS=1500
