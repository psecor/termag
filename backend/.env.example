# =============================================================================
# termag backend configuration
# =============================================================================
# Copy this file to .env and fill in real values. Variables without a default
# are required.

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/termag"

# Public-facing URL where the frontend is served. Must match what your reverse
# proxy exposes (Slack OAuth callbacks and CORS depend on this).
FRONTEND_URL="https://example.com"

# Subpath the app is mounted at behind the reverse proxy. Use "" if mounted at
# the domain root, or e.g. "/termag" if proxied at https://example.com/termag.
BASE_PATH="/termag"

# Port the Express server listens on (your reverse proxy forwards to this).
PORT=3040

# Express session secret. Generate with: openssl rand -hex 32
SESSION_SECRET="replace-with-random-secret"

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Google OAuth — create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# Comma-separated list of allowed Google sign-ins. Each entry is one of:
#   email:unixuser        exact mapping (highest priority)
#   @domain.com           anyone in the domain; unix username = email local part
#   @domain.com:unixuser  anyone in the domain mapped to a fixed unix username
# Example: ALLOWED_USERS="admin@example.com:root,@example.org"
# Note: unix usernames are NOT auto-provisioned on the host — make sure each
# mapped or derived username corresponds to a real unix user, or the account's
# first agent operation will fail.
ALLOWED_USERS="you@example.com:youruser"

# -----------------------------------------------------------------------------
# Slack integration (optional — leave unset to disable)
# -----------------------------------------------------------------------------

# Slack app credentials. Create the app at https://api.slack.com/apps
# Required scopes are documented in deploy/setup.md.
SLACK_BOT_TOKEN="xoxb-..."
SLACK_APP_TOKEN="xapp-..."          # Socket Mode app-level token
SLACK_SIGNING_SECRET="..."

# Comma-separated list mapping allowed Slack user IDs → unix usernames.
# Format: U01ABCDEF:youruser,U02GHIJKL:otheruser
ALLOWED_SLACK_USERS="U01ABCDEF:youruser"

# -----------------------------------------------------------------------------
# Discord integration (optional — leave unset to disable)
# -----------------------------------------------------------------------------

DISCORD_TOKEN=""
DISCORD_APP_ID=""

# Comma-separated list mapping Discord user IDs → unix usernames.
# Format: 123456789012345678:youruser
DISCORD_USER_MAP=""

# -----------------------------------------------------------------------------
# Local relay (Chrome tab capture)
# -----------------------------------------------------------------------------

# Token the local Chrome relay uses to authenticate to the backend.
# Generate with: openssl rand -hex 32
RELAY_TOKEN="replace-with-random-relay-token"

# -----------------------------------------------------------------------------
# Pane capture API (used by Claude Code Stop hook → backend)
# -----------------------------------------------------------------------------

# Shared secret hooks use to POST captured panes to the backend.
# Generate with: openssl rand -hex 32
CAPTURE_API_SECRET="replace-with-random-capture-secret"

# -----------------------------------------------------------------------------
# Box provisioning (optional — the "Add box" button)
# -----------------------------------------------------------------------------
# When all required vars below are set, POST /api/instances launches an EC2 box
# via the AWS SDK under a locked-down IAM grant (per-box role + permissions
# boundary, tag-scoped EC2/ALB actions). Leave them unset to fall back to the
# legacy manual-terraform path (POST returns a raw token to paste into
# `terraform apply` in terraform/box/). Most values come from your own
# Terraform that wires up the IAM grant. Credentials come from the
# orchestrator's own instance role (no keys here).
#
# AWS region the boxes (and the SDK clients) live in.
# AWS_REGION="us-east-1"
#
# WebSocket URL the box's agent dials. Baked into the box's user_data.
# AGENT_WS_URL="wss://example.com/termag/ws/agent"
#
# Prefix for every per-box AWS resource (SG / role / instance profile). Must
# match the grant's resource-name condition. Grant output: box_resource_prefix.
# BOX_RESOURCE_PREFIX="termag-box"
#
# Permissions boundary applied to each per-box role (the grant denies
# CreateRole without it). Grant output: box_permissions_boundary_arn.
# BOX_PERMISSIONS_BOUNDARY_ARN="arn:aws:iam::ACCOUNT:policy/termag-box-boundary"
#
# VPC + private subnet (NAT route for outbound; no public IP) the boxes launch in.
# BOX_VPC_ID="vpc-..."
# BOX_SUBNET_ID="subnet-..."
#
# The orchestrator's ALB security group — boxes get a 443 ingress rule added so
# their agent can reach the orchestrator. Grant output: alb_security_group_id.
# ALB_SECURITY_GROUP_ID="sg-..."
#
# Instance type — MUST be arm64/Graviton; the box AMI is arm64-only. Default t4g.medium.
# BOX_INSTANCE_TYPE="t4g.medium"
#
# ManagedBy tag value the grant scopes tag-conditioned actions on. Default
# "termag-box". Must match the tag your IAM grant scopes on.
# BOX_MANAGED_TAG="termag-box"
#
# Root EBS volume size in GB. Default 30.
# BOX_ROOT_VOLUME_GB="30"
#
# Optional: Secrets Manager ARN of a private-repo git PAT. When set, each box's
# role gets read access to just this secret (the box reads it at boot — it is
# deliberately NOT placed in user_data).
# BOX_GIT_TOKEN_SECRET_ARN="arn:aws:secretsmanager:REGION:ACCOUNT:secret:..."

# -----------------------------------------------------------------------------
# Tunables (all have defaults — override only if needed)
# -----------------------------------------------------------------------------

# Max seconds to wait for a `claude` CLI invocation before killing it.
CLAUDE_TIMEOUT_SECONDS=120

# Max characters of agent output sent back in a Slack/Discord response.
MAX_RESPONSE_LENGTH=3500

# Min seconds between successive DM commands from the same user.
RATE_LIMIT_SECONDS=2

# How often (ms) to flush partial streaming updates to Slack/Discord.
STREAMING_UPDATE_INTERVAL_MS=1500
