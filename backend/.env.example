DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/termag"

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# Must match the Apache-proxied URL
FRONTEND_URL="https://secorp.net"
BASE_PATH="/termag"

# openssl rand -hex 32
SESSION_SECRET="replace-with-random-secret"

# Port for the Express server (Apache proxies this)
PORT=3040

# Comma-separated list of allowed Google emails → unix usernames
# Format: email:unixuser,email2:unixuser2
ALLOWED_USERS="secorp@gmail.com:secorp"

# Token the local Chrome relay uses to authenticate
# openssl rand -hex 32
RELAY_TOKEN="replace-with-random-relay-token"
