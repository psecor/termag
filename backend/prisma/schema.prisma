generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  googleId     String    @unique
  googleEmail  String    @unique
  unixUsername String    @unique
  displayName   String
  defaultAgentProvider String @default("codex")
  slackUserId   String?   @unique
  discordUserId String?   @unique
  createdAt     DateTime  @default(now())

  projects    Project[]
  agentTokens AgentToken[]

  @@map("users")
}

model AgentToken {
  id         String    @id @default(cuid())
  name       String    // e.g. "macbook", "dev-server"
  tokenHash  String    @unique // SHA-256 hash of the token
  tokenPrefix String   // first 8 chars for display (e.g. "tmag_a1b2...")
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("agent_tokens")
}

model Project {
  id             String    @id @default(cuid())
  name           String
  description    String?
  color          String?   // hex color for UI differentiation
  slackChannelId String?   // Slack channel ID (proj-<name>)
  archived       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  workflows   Workflow[]
  browserTabs BrowserTab[]

  @@unique([userId, name])
  @@index([userId, archived])
  @@map("projects")
}

model Workflow {
  id        String       @id @default(cuid())
  type      WorkflowType
  provider  String?
  server    String       @default("localhost") // future: ssh to other servers
  createdAt DateTime     @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type])
  @@map("workflows")
}

enum WorkflowType {
  agent
  data
}

// AgentProvider is now a plain String validated at the application layer
// via PROVIDER_IDS from backend/src/providers/registry.ts.
// This avoids a DB migration every time a new provider is added.


model BrowserTab {
  id        String   @id @default(cuid())
  url       String
  title     String
  favIcon   String?
  windowId  Int?     // Chrome window ID from CDP snapshot
  addedAt   DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("browser_tabs")
}

// Notification targets — which channels to notify when a tmux session needs input
// Supports both Slack and Discord; one entry per session+platform pair
model NotificationTarget {
  tmuxSession String              // e.g. "secorp-mommo-site-agent"
  platform    String              // "slack" or "discord"
  channel     String              // platform channel ID
  userId      String              // platform user ID
  updatedAt   DateTime @default(now()) @updatedAt

  @@id([tmuxSession, platform])
  @@map("notification_targets")
}

// Working time accumulated from status transitions (working → idle/waiting)
model WorkTimeEntry {
  id        String   @id @default(cuid())
  username  String
  project   String
  provider  String
  date      String   // YYYY-MM-DD
  totalMs   Int      @default(0)
  sessions  Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([username, project, provider, date])
  @@index([username, date])
  @@map("work_time_entries")
}

// Latest Chrome tab snapshot from the local relay, keyed by relay token
model RelaySnapshot {
  id          String   @id @default(cuid())
  relayToken  String   @unique
  snapshotAt  DateTime @default(now())
  windows     Json     // array of { windowId, tabs: [{ url, title, favIcon }] }

  @@map("relay_snapshots")
}
