generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  googleId     String    @unique
  googleEmail  String    @unique
  unixUsername String    @unique
  displayName  String
  slackUserId  String?   @unique
  createdAt    DateTime  @default(now())

  projects    Project[]
  agentTokens AgentToken[]

  @@map("users")
}

model AgentToken {
  id         String    @id @default(cuid())
  name       String    // e.g. "macbook", "dev-server"
  tokenHash  String    @unique // SHA-256 hash of the token
  tokenPrefix String   // first 8 chars for display (e.g. "tmag_a1b2...")
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("agent_tokens")
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  color       String?   // hex color for UI differentiation
  archived    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  workflows   Workflow[]
  browserTabs BrowserTab[]

  @@unique([userId, name])
  @@index([userId, archived])
  @@map("projects")
}

model Workflow {
  id        String       @id @default(cuid())
  type      WorkflowType
  server    String       @default("localhost") // future: ssh to other servers
  createdAt DateTime     @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type])
  @@map("workflows")
}

enum WorkflowType {
  agent
  data
}


model BrowserTab {
  id        String   @id @default(cuid())
  url       String
  title     String
  favIcon   String?
  windowId  Int?     // Chrome window ID from CDP snapshot
  addedAt   DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("browser_tabs")
}

// Slack notification targets — which channel to notify when a tmux session needs input
model NotificationTarget {
  tmuxSession String   @id        // e.g. "secorp-mommo-site-agent"
  channel     String              // Slack channel ID
  userId      String              // Slack user ID
  updatedAt   DateTime @default(now()) @updatedAt

  @@map("notification_targets")
}

// Latest Chrome tab snapshot from the local relay, keyed by relay token
model RelaySnapshot {
  id          String   @id @default(cuid())
  relayToken  String   @unique
  snapshotAt  DateTime @default(now())
  windows     Json     // array of { windowId, tabs: [{ url, title, favIcon }] }

  @@map("relay_snapshots")
}
